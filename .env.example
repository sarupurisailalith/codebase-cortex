# LLM Provider (google or anthropic)
LLM_PROVIDER=google

# Google Gemini
GOOGLE_API_KEY=your-google-api-key

# Anthropic (optional fallback)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# GitHub (optional - only needed for remote repo URLs)
# GITHUB_TOKEN=your-github-pat

# Target repository path (local path or GitHub URL)
REPO_PATH=.

# Notion OAuth tokens are stored in data/notion_tokens.json
# They are managed automatically by `cortex init`
