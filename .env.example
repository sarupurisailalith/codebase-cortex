# This file shows the format of .cortex/.env
# Created automatically by `cortex init` — you don't need to create it manually.

# LLM Provider (google or anthropic)
LLM_PROVIDER=google

# Google Gemini
GOOGLE_API_KEY=your-google-api-key

# Anthropic (optional fallback)
# ANTHROPIC_API_KEY=your-anthropic-api-key

# GitHub (optional - only needed for private repos)
# GITHUB_TOKEN=your-github-pat

# Notion OAuth tokens are stored in .cortex/notion_tokens.json
# They are managed automatically by `cortex init`
